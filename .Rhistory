# Carregar o mapa do Espírito Santo
mapa_es <- read_municipality(code_muni = "ES", year = 2020)
# Municípios a destacar
municipios_mapa <- c("Água Doce Do Norte", "Anchieta", "Vila Pavão")
# Cores para cada município
cores <- c(
"Água Doce Do Norte" = "red",
"Anchieta"           = "blue",
"Vila Pavão"         = "green"
)
# Criar coluna de cor — municípios destacados recebem seu nome, os demais "Outros"
mapa_es <- mapa_es %>%
mutate(cor = ifelse(name_muni %in% municipios_mapa, name_muni, "Outros"))
# Calcular bounding box automaticamente a partir dos dados
bbox <- st_bbox(mapa_es)
# Plotar
ggplot(mapa_es) +
geom_sf(aes(fill = cor), color = "white", size = 0.2) +
scale_fill_manual(
values = c(cores, "Outros" = "gray90"),
name   = "Municípios",
breaks = c("Água Doce Do Norte", "Anchieta", "Vila Pavão", "Outros")
) +
labs(title = "Mapa dos Municípios Destacados no Espírito Santo") +
theme_minimal() +
theme(
plot.title       = element_text(hjust = 0.5, face = "bold", size = 16),
legend.position  = "right",
panel.grid       = element_blank(),   # remove grade cartesiana
axis.text        = element_blank(),   # remove rótulos dos eixos
axis.ticks       = element_blank(),   # remove marcações dos eixos
plot.margin      = margin(10, 10, 10, 10)
) +
coord_sf(
xlim   = c(bbox["xmin"], bbox["xmax"]),
ylim   = c(bbox["ymin"], bbox["ymax"]),
expand = 0.05   # 5% de margem ao redor do mapa
)
