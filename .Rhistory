dados <- read_excel("rojecoes_2024_tab3_grupos_etarios_especificos.xlsx", skip = 6)
# Ler dados de projeção populacional
dados <- read_excel("projecoes_2024_tab3_grupos_etarios_especificos.xlsx", skip = 6)
# Carregamento das bibliotecas
library(readxl)
library(dplyr)
library(ggplot2)
library(scales)
library(tidyr)
library(tidyverse)
library(openxlsx)
library(knitr)
library(kableExtra)
library(microdatasus)
# Ler dados de projeção populacional
dados <- read_excel("projecoes_2024_tab3_grupos_etarios_especificos.xlsx", skip = 6)
# Filtrar RJ e Anos 2010 a 2023
dados_rj <- dados %>%
filter(SIGLA == "RJ", ANO >= 2010, ANO <= 2023)
# Gráfico de barras
ggplot(data = dados_rj, aes(x = factor(ANO), y = POP_T)) +
geom_bar(stat = "identity", fill = "steelblue") +
geom_text(aes(label = comma(POP_T)), vjust = -0.5, size = 2.8) +
scale_x_discrete(breaks = as.character(2010:2023)) +
scale_y_continuous(labels = comma) +
theme_minimal() +
labs(
title = "População do Estado do Rio de Janeiro (2010-2023)",
x = "Ano",
y = "População Total"
) +
theme(
axis.text.x = element_text(angle = 45, hjust = 1),
plot.title = element_text(hjust = 0.5)
)
View(dados_rj)
# Calcular taxa de crescimento populacional
dados_rj_crescimento <- dados %>%
filter(SIGLA == "RJ", ANO >= 2009, ANO <= 2023) %>%
arrange(ANO) %>%
mutate(taxa_cresc = (POP_T - lag(POP_T)) / lag(POP_T) * 100) %>%
filter(ANO >= 2010)
# Taxa total do período
pop_2010 <- dados %>% filter(SIGLA == "RJ", ANO == 2010) %>% pull(POP_T)
pop_2023 <- dados %>% filter(SIGLA == "RJ", ANO == 2023) %>% pull(POP_T)
taxa_total <- (pop_2023 - pop_2010) / pop_2010 * 100
cat(paste("Taxa de crescimento total de 2010 a 2023:", round(taxa_total, 2), "%\n"))
# Gráfico
ggplot(data = dados_rj_crescimento, aes(x = factor(ANO), y = taxa_cresc)) +
geom_bar(stat = "identity", fill = "darkgreen") +
geom_text(aes(label = paste0(round(taxa_cresc, 2), "%")), vjust = -0.5, size = 3.5) +
scale_x_discrete(breaks = as.character(2010:2023)) +
scale_y_continuous(labels = function(x) paste0(round(x, 2), "%")) +
theme_minimal() +
labs(
title = "Taxa de Crescimento Populacional Anual do Rio de Janeiro (2010-2023)",
x = "Ano",
y = "Taxa de Crescimento (%)"
) +
theme(
axis.text.x = element_text(angle = 45, hjust = 1),
plot.title = element_text(hjust = 0.5)
)
View(dados_rj_crescimento)
View(dados_rj_crescimento)
# Calcular taxa de crescimento populacional
dados_rj_crescimento <- dados %>%
filter(SIGLA == "RJ", ANO >= 2009, ANO <= 2023) %>%
arrange(ANO) %>%
mutate(taxa_cresc = (POP_T - lag(POP_T)) / lag(POP_T) * 100) %>%
filter(ANO >= 2010)
# Taxa total do período
pop_2010 <- dados %>% filter(SIGLA == "RJ", ANO == 2010) %>% pull(POP_T)
pop_2023 <- dados %>% filter(SIGLA == "RJ", ANO == 2023) %>% pull(POP_T)
taxa_total <- (pop_2023 - pop_2010) / pop_2010 * 100
cat(paste("Taxa de crescimento total de 2010 a 2023:", round(taxa_total, 2), "%\n"))
# Gráfico
ggplot(data = dados_rj_crescimento, aes(x = factor(ANO), y = taxa_cresc)) +
geom_bar(stat = "identity", fill = "darkgreen") +
geom_text(aes(label = paste0(round(taxa_cresc, 2), "%")), vjust = -0.5, size = 3.5) +
scale_x_discrete(breaks = as.character(2010:2023)) +
scale_y_continuous(labels = function(x) paste0(round(x, 2), "%")) +
theme_minimal() +
labs(
title = "Taxa de Crescimento Populacional Anual do Rio de Janeiro (2010-2023)",
x = "Ano",
y = "Taxa de Crescimento (%)"
) +
theme(
axis.text.x = element_text(angle = 45, hjust = 1),
plot.title = element_text(hjust = 0.5)
)
View(dados_rj_crescimento)
# Dados 2010
dados_2010 <- read_excel("C:/Users/lucas/Downloads/Trabalho 1/piramide2010.xls", skip = 7, col_names = FALSE)
pop_total_2010 <- as.numeric(dados_2010[[2]][1])
pop_urbana_2010 <- as.numeric(dados_2010[[5]][1])
urban_rate_2010 <- (pop_urbana_2010 / pop_total_2010) * 100
df_2010 <- data.frame(Ano = "2010", Taxa = urban_rate_2010)
# Dados 2022
dados_2022 <- read_excel("C:/Users/lucas/Downloads/Trabalho 1/taxadeurbanizacao2022.xlsx", skip = 4)
dados_rj_2022 <- dados_2022 %>% filter(.[[1]] == "Rio de Janeiro")
urbana_2022 <- sum(as.numeric(dados_rj_2022[[2]]), na.rm = TRUE)
rural_2022 <- sum(as.numeric(dados_rj_2022[[3]]), na.rm = TRUE)
urban_rate_2022 <- (urbana_2022 / (urbana_2022 + rural_2022)) * 100
df_2022 <- data.frame(Ano = "2022", Taxa = urban_rate_2022)
# Combinar dados
df_comparacao <- rbind(df_2010, df_2022)
# Gráfico comparativo
ggplot(df_comparacao, aes(x = Ano, y = Taxa, fill = Ano)) +
geom_bar(stat = "identity", width = 0.7) +
geom_text(aes(label = sprintf("%.2f%%", Taxa)),
color = "black", vjust = -0.5, size = 4) +
scale_fill_manual(values = c("2010" = "lightblue", "2022" = "#dfcccc")) +
scale_y_continuous(labels = function(x) paste0(x, "%"),
limits = c(0, max(df_comparacao$Taxa) * 1.1)) +
labs(title = "Comparação da Taxa de Urbanização do Rio de Janeiro: 2010 vs 2022",
x = "Ano",
y = "Taxa de Urbanização (%)",
fill = "Ano") +
theme_minimal() +
