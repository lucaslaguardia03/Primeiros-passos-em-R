## Quais os municípios que apresentaram a indústria extrativa como a principal, a segunda ou a terceira mais importante atividade econômica?

Os municípios Água Doce do Norte, Anchieta e Vila Pavão apresentaram a indústria extrativa como a principal, a segunda ou a terceira mais importante atividade econômica no Espírito Santo em 2021, conforme demonstra a tabela abaixo:

```{r tabela_top3}
# ------------------------------
# Leitura da planilha
# ------------------------------
dados <- read_excel(
  path = "1a.xlsx",
  skip = 1
)

colnames(dados)[1] <- "Município"

# ------------------------------
# Converte TODAS as colunas B:T para numéricas
# remove vírgulas, pontos e espaços antes
# ------------------------------
dados[, 2:21] <- dados[, 2:21] |> 
  mutate(across(
    everything(),
    ~ as.numeric(gsub(",", ".", gsub("[^0-9,]", "", as.character(.))))
  ))

# ------------------------------
# Identificação das top 3 atividades
# ------------------------------
resultados <- dados %>%
  pivot_longer(
    cols = 2:21,
    names_to = "Atividade",
    values_to = "Vinculos"
  ) %>%
  group_by(Município) %>%
  arrange(desc(Vinculos), .by_group = TRUE) %>%
  slice_head(n = 3) %>%
  mutate(Posicao = paste0(row_number(), "º")) %>%
  ungroup() %>%
  select(Município, Posicao, Atividade) %>%
  pivot_wider(
    names_from = Posicao,
    values_from = Atividade
  )

# ------------------------------
# Vírgula como separador decimal
# ------------------------------
options(OutDec = ",")

# ------------------------------
# Tabela formatada (todos os municípios)
# ------------------------------
kable(
  resultados,
  format = "html",
  col.names = c("Município", "1º", "2º", "3º"),
  caption = paste0("<div style='text-align:center; color:black; font-weight:bold; font-size:16px;'>Tabela ", tabela_counter, " - Atividades econômicas com mais vínculos por município - Espírito Santo (2021)</div>"),
  align = "lccc",
  escape = FALSE
) %>%
  kable_styling(
    full_width = FALSE,
    position = "center",
    font_size = 14,
    bootstrap_options = c("striped", "hover", "condensed")
  ) %>%
  footnote(
    general = "Fonte: RAIS (2021) - Elaboração própria. Classificação conforme o número de vínculos formais de trabalho.",
    general_title = "",
    footnote_as_chunk = TRUE
  )

# Incrementa contador
tabela_counter <<- tabela_counter + 1

# ------------------------------
# Lista dos municípios com Indústrias Extrativas no top 3
# ------------------------------
lista_unificada <- resultados %>%
  filter(
    `1º` == "Indústrias Extrativas" |
    `2º` == "Indústrias Extrativas" |
    `3º` == "Indústrias Extrativas"
  ) %>%
  pull(Município) %>%
  paste(collapse = ", ")
```

**Municípios identificados:** `r lista_unificada`

## Represente a resposta anterior em um mapa.

```{r mapa_municipios}
# Função para normalizar nomes
normalize_name <- function(x) {
  x <- tolower(x)
  x <- iconv(x, from = "UTF-8", to = "ASCII//TRANSLIT")
  return(trimws(x))
}

# Divida a string em vetores individuais e normalize
nomes_brutos <- trimws(strsplit(lista_unificada, ",")[[1]])
nomes_normalizados <- sapply(nomes_brutos, normalize_name)

# Baixe os dados geográficos dos municípios do Espírito Santo
mun_es <- read_municipality(code_muni = "ES", year = 2020)

# Normalize os nomes no dataset
mun_es$nome_normalizado <- sapply(mun_es$name_muni, normalize_name)

# Filtre os municípios a serem destacados
mun_destaque <- mun_es %>%
  filter(nome_normalizado %in% nomes_normalizados) %>%
  mutate(
    cor = case_when(
      name_muni == "Água Doce do Norte" ~ "purple",
      name_muni == "Anchieta" ~ "blue",
      name_muni == "Vila Pavão" ~ "green",
      TRUE ~ "red"
    ),
    ordem = case_when(
      name_muni == "Água Doce do Norte" ~ 1,
      name_muni == "Anchieta" ~ 2,
      name_muni == "Vila Pavão" ~ 3,
      TRUE ~ 0
    )
  ) %>%
  arrange(ordem)

# Calcule os centróides para posicionar os labels
mun_destaque_centroids <- st_centroid(mun_destaque) %>%
  mutate(
    x = st_coordinates(.)[,1],
    y = st_coordinates(.)[,2]
  )

# Crie o mapa com título personalizado
mapa_es <- ggplot(data = mun_es) +
  geom_sf(fill = "lightgray", color = "white", size = 0.7) +
  geom_sf(data = mun_destaque, aes(fill = name_muni), color = "black", size = 0.5, alpha = 0.7) +
  scale_fill_manual(
    values = setNames(mun_destaque$cor, mun_destaque$name_muni),
    name = "Municípios Destacados"
  ) +
  geom_text_repel(
    data = mun_destaque_centroids,
    aes(x = x, y = y, label = name_muni),
    size = 3,
    color = "black",
    fontface = "bold",
    box.padding = 0.5,
    point.padding = 0.5,
    max.overlaps = Inf
  ) +
  theme_void() +
  theme(
    legend.position = "bottom",
    plot.title = element_text(hjust = 0.5, size = 9, face = "bold", color = "black", margin = margin(b = 10)),
    plot.caption = element_text(hjust = 0.5, size = 8, color = "black", margin = margin(t = 5)),
    plot.margin = unit(c(0.5, 0.001, 0.001, 0.001), "cm")
  ) +
  labs(
    title = paste0("Mapa ", mapa_counter, " - Municípios capixabas com indústria extrativa entre as três principais atividades econômicas em 2021"),
    caption = "Fonte: RAIS (2021) e IBGE (2020) - Elaboração própria."
  ) +
  coord_sf(crs = 4674, datum = NA, expand = TRUE) +
  annotation_scale(location = "br", width_hint = 0.15, height = unit(0.15, "cm"), 
                   line_width = 0.5, text_cex = 0.8) +
  annotation_north_arrow(location = "tr", which_north = "true", 
                         style = north_arrow_fancy_orienteering, width = unit(1.2, "cm"))

print(mapa_es)

# Incrementa contador
mapa_counter <<- mapa_counter + 1
```

