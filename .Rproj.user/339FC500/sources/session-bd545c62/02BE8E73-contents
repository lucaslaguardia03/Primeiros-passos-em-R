##Quais os municípios que apresentaram a indústria extrativa como a principal, a segunda ou a terceira mais importante atividade econômica?

Os municípios `r reposta_questao1` apresentaram a indústria extrativa como a principal, a segunda ou a terceira mais importante atividade econômica no Espírito Santo em 2021, conforme demonstra a tabela abaixo:


```{r questao_1.1, echo=FALSE}

#Ler planilha excel

dados_questao1 <- read_excel("Atividades - ES 2021.xlsx", skip = 1)

colnames(dados_questao1)[1] <- "Município"

#Ordenar atividades com mais vínculos

atividades_ordenadas <- dados_questao1 %>% 
  pivot_longer(cols = 2:21, names_to = "Atividade", values_to = "Vínculos") %>% 
  group_by(Município) %>% 
  arrange(desc(Vínculos), .by_group = TRUE) %>% 
  slice_head(n = 3) %>% 
  mutate(Posição = paste0(row_number(), "º")) %>% 
  ungroup() %>% 
  select(Município, Atividade, Posição) %>% 
  pivot_wider(values_from = Atividade, names_from = Posição)
  
#Ordenar atividades com mais vínculos

kable(atividades_ordenadas, 
      col.names = c("Município", "1º", "2º", "3º"), caption = paste0(
  "<center><span style='color:black; font-weight:bold;'>",
  "Tabela ", n_tabela, " - Atividades econômicas com mais vínculos por município - Espírito Santo (2021)",
  "</span></center>"),
       align = "c") %>% 
  
 kable_styling(
    full_width = FALSE,
    position = "center",
    font_size = 14,
    bootstrap_options = c("striped", "hover", "condensed")
  ) %>%
  
  footnote(
    general = "Fonte: RAIS (2021) - Elaboração própria. Classificação conforme o número de vínculos formais de trabalho.",
    general_title = "",
    footnote_as_chunk = TRUE)

# Resultado

resposta_questao1 <- atividades_ordenadas %>% 
  filter( `1º` == "Indústrias Extrativas" |
    `2º` == "Indústrias Extrativas" |
    `3º` == "Indústrias Extrativas") %>% 
  pull(Município) %>% 
  paste(collapse = ", ")
```

# Represente a resposta anterior em um mapa.

```{r mapa_questao1, echo=FALSE}

# Carregar o mapa do Espírito Santo
mapa_es <- read_municipality(code_muni = "ES", year = 2020)

# Municípios a destacar
municipios_mapa <- c("Água Doce Do Norte", "Anchieta", "Vila Pavão")

# Cores para cada município
cores <- c(
  "Água Doce Do Norte" = "red",
  "Anchieta"           = "blue",
  "Vila Pavão"         = "green"
)

# Criar coluna de cor
mapa_es <- mapa_es %>%
  mutate(cor = ifelse(name_muni %in% municipios_mapa, name_muni, "Outros"))

ggplot(mapa_es) +
  geom_sf(aes(fill = cor), color = "white", linewidth = 0.2) +
  geom_label(
    data = centroides,
    aes(x = lon, y = lat, label = name_muni),
    size          = 3,
